[Unit]
Description=Ziwei FastAPI Service
After=network.target postgresql.service

[Service]
User=root
WorkingDirectory=/root/ziwei-server
EnvironmentFile=/root/ziwei-server/.env
ExecStart=/root/ziwei-server/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8003 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
